# === إعدادات بوت حمد نت ===
# انسخ هذا الملف كـ .env واملأ القيم

# === بوت Telegram ===
BOT_TOKEN=ضع_توكن_البوت_هنا
ADMIN_CHAT_ID=ضع_معرف_المحادثة_هنا

# === اسم الشبكة ===
NETWORK_NAME=حمد نت

# === إعدادات الراوتر ===
# نوع الراوتر: mikrotik أو openwrt
ROUTER_TYPE=mikrotik
ROUTER_HOST=192.168.1.1
ROUTER_USER=admin
ROUTER_PASS=ضع_كلمة_مرور_الراوتر
ROUTER_API_PORT=8728

# === إعدادات الشبكة ===
NETWORK_SUBNET=192.168.1.0/24
SCAN_INTERVAL=60
INTERNET_CHECK_INTERVAL=30
TRAFFIC_UPDATE_INTERVAL=300

# === إعدادات التنبيهات ===
ALERT_ON_NEW_DEVICE=true
ALERT_ON_DEVICE_LEAVE=true
ALERT_ON_INTRUSION=true
ALERT_ON_INTERNET_DOWN=true
ALERT_ON_TOPOLOGY_CHANGE=true
ALERT_ON_HIGH_CPU=true
CPU_THRESHOLD=90

# === قاعدة البيانات ===
DB_PATH=hamad_net.db
