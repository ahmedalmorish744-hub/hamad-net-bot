# === إعدادات بوت حمد نت ===
# انسخ هذا الملف إلى .env وقم بتعديل القيم

# === تليجرام ===
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# معرفات المحادثات المصرح لها (افصل بفاصلة)
AUTHORIZED_CHAT_IDS=

# === نوع الراوتر ===
# mikrotik أو openwrt
ROUTER_TYPE=mikrotik

# === إعدادات MikroTik ===
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_PORT=8728

# === إعدادات OpenWrt ===
OPENWRT_HOST=192.168.1.1
OPENWRT_USER=root
OPENWRT_PASSWORD=
OPENWRT_PORT=22

# === إعدادات الشبكة ===
NETWORK_SUBNET=192.168.1.0/24
NETWORK_GATEWAY=192.168.1.1
NETWORK_NAME=حمد نت

# === فترات المراقبة (بالثانية) ===
SCAN_INTERVAL=300
PING_INTERVAL=60
SECURITY_CHECK_INTERVAL=120
BANDWIDTH_MONITOR_INTERVAL=30

# === التنبيهات ===
ALERT_ON_NEW_DEVICE=true
ALERT_ON_DEVICE_LEAVE=true
ALERT_ON_INTRUSION=true
ALERT_ON_OUTAGE=true
ALERT_ON_CONFIG_CHANGE=true
ALERT_ON_HIGH_BANDWIDTH=true
HIGH_BANDWIDTH_THRESHOLD=100

# === Starlink ===
STARLINK_ENABLED=false
STARLINK_IP=192.168.100.1

# === متقدم ===
DATABASE_PATH=data/hamad_net.db
MAX_LOG_ENTRIES=1000
AUTO_BLOCK_INTRUSION=false
NOTIFICATION_LANGUAGE=ar
